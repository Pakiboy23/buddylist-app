{
	"appId": "com.hiitsme.app",
	"appName": "H.I.M.",
	"webDir": "native-web",
	"ios": {
		"scheme": "HIM"
	},
	"plugins": {
		"StatusBar": {
			"overlaysWebView": false,
			"style": "LIGHT",
			"backgroundColor": "#13100E"
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		}
	},
	"packageClassList": [
		"BiometricAuthNative",
		"HapticsPlugin",
		"LocalNotificationsPlugin",
		"PushNotificationsPlugin",
		"BadgePlugin"
	]
}
