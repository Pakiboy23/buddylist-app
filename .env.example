# Public (client-side) — exposed to the browser bundle via Vite
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: override the native Capacitor backend origin if it differs from production web.
VITE_APP_API_ORIGIN=https://hiitsme-app.vercel.app

# Server-side — used by Vercel Serverless Functions (api/) only, never exposed to the browser
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Apple Push Notifications (server-side only)
APPLE_PUSH_KEY_ID=
APPLE_PUSH_TEAM_ID=
APPLE_PUSH_PRIVATE_KEY=
APPLE_PUSH_TOPIC=com.hiitsme.app

# Optional: Playwright E2E credentials for seeded test accounts.
PLAYWRIGHT_USER_A_SCREENNAME=your-screenname-a
PLAYWRIGHT_USER_A_PASSWORD=your-password-a
PLAYWRIGHT_USER_B_SCREENNAME=your-screenname-b
PLAYWRIGHT_USER_B_PASSWORD=your-password-b
